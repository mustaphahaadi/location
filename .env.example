# Tunnel: cloudflare (default, no warning page) or ngrok (free tier shows warning)
TUNNEL=cloudflare

# Only needed if TUNNEL=ngrok
NGROK_AUTHTOKEN=your_token_here

# Server
PORT=8000
HOST=0.0.0.0
USE_TUNNEL=1

# Optional: skip tunnel and set your own public HTTPS base URL
# PUBLIC_BASE_URL=https://your-domain.com

# Path to tunnel binaries (auto-detected by run.sh)
# CLOUDFLARED_BIN=./bin/cloudflared
# NGROK_BIN=/snap/bin/ngrok

# Dev hot-reload (off by default)
# RELOAD=1
