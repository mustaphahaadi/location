# --- Local development (./run.sh) ---
TUNNEL=cloudflare
NGROK_AUTHTOKEN=your_token_here
PORT=8000
HOST=0.0.0.0
USE_TUNNEL=1
# LOCATION_STORAGE=auto   # file on disk when USE_TUNNEL=1

# --- Deployed (Vercel, Render, Railway, Fly, Docker) ---
# USE_TUNNEL=0
# LOCATION_STORAGE=kv          # Vercel: link a KV store (auto-injects KV_REST_API_*)
# LOCATION_STORAGE=memory      # Docker/single-server without KV
# PUBLIC_BASE_URL=https://your-app.example.com
# (Vercel/Render/Railway/Fly URLs are auto-detected when PUBLIC_BASE_URL is unset)

# Path to tunnel binaries (auto-detected by run.sh)
# CLOUDFLARED_BIN=./bin/cloudflared
# NGROK_BIN=/snap/bin/ngrok

# Dev hot-reload (off by default)
# RELOAD=1
